{
  "name": "bdr-commission-backend",
  "version": "1.0.0",
  "description": "API de comissionamento BDR",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval:diagnostico": "ts-node -r dotenv/config scripts/eval-diagnostico.ts",
    "auditar:retencao": "ts-node -r dotenv/config scripts/auditar-retencao.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@notionhq/client": "^5.22.0",
    "@prisma/client": "^5.14.0",
    "axios": "^1.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0",
    "multer": "^2.1.1",
    "mysql2": "^3.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.12.0",
    "puppeteer": "^25.3.0",
    "uuid": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
