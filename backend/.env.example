# PostgreSQL (escrita - banco próprio)
DATABASE_URL="postgresql://bdr_user:bdr_password@postgres:5432/bdr_commission"

# MariaDB IXC ERP (somente leitura) — driver mysql2 é compatível
MYSQL_HOST=192.168.1.100
MYSQL_PORT=3306
MYSQL_USER=readonly_user
MYSQL_PASSWORD=readonly_password
MYSQL_DATABASE=ixc_erp

# Servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=troque_por_uma_chave_forte_e_aleatoria

# IXC API
IXC_TOKEN=seu_token_ixc_aqui
IXC_HOST=https://seu-host-ixc.com.br

# IXC — login de sessão (usuário de integração dedicado, não o token acima).
# Necessário só para o módulo Diagnóstico visualizar fotos/anexos de O.S.,
# rota que a API por token não alcança.
IXC_ADMIN_LOGIN=usuario.integracao@exemplo.com.br
IXC_ADMIN_SENHA=troque_por_uma_senha_forte

# Alertas por e-mail (separar múltiplos destinatários por vírgula)
ALERT_EMAIL_COMERCIAL=comercial@exemplo.com.br
ALERT_EMAIL_SAC=sac@exemplo.com.br
ALERT_EMAIL_FINANCEIRO=financeiro@exemplo.com.br
# Cópia extra opcional no e-mail de comissão aprovada (ex: gestor que acompanha o envio ao financeiro)
ALERT_EMAIL_CC_EXTRA=
ALERT_EMAIL_FROM="Canaã Performance" <contato@exemplo.com.br>

# URL pública base do sistema (usada em links de e-mails de alerta)
BASE_URL=https://exemplo.com.br

# Destinatário do script pontual scripts/reenviar-copia.ts
REENVIO_COPIA_EMAIL_TO=gestor@exemplo.com.br

# SMTP (envio de e-mail — usado por config/mailer.ts e agenda.email.ts)
SMTP_HOST=smtp.exemplo.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario_smtp
SMTP_PASS=troque_por_uma_senha_forte
SMTP_FROM="Nome da Empresa <noreply@exemplo.com.br>"

# ── Sistema de Agendamento de Salas ──────────────────────────
AGENDA_DB_HOST=localhost
AGENDA_DB_USER=postgres
AGENDA_DB_NAME=sistema_db
AGENDA_DB_PASS=troque_por_uma_senha_forte

# Nome do colaborador responsável por validar tentativas STARK no histórico do IXC
STARK_VALIDADOR_NOME=NOME SOBRENOME
STARK_VALIDADOR_NOME_COMPLETO=NOME SOBRENOME COMPLETO (STARK)

# Operadoras autorizadas no módulo de Retenção (separar múltiplos nomes por vírgula)
RETENCAO_OPERADORES_CS=NOME SOBRENOME UM,NOME SOBRENOME DOIS

# ── Diagnóstico IA (Gemini) ──────────────────────────────────
# GEMINI_API_KEY=troque_pela_chave_real
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_MODEL_FALLBACK=gemini-flash-lite-latest
# Preço opcional (US$ por 1 milhão de tokens) só para estimar custo em
# GET /diagnostico/_health/gemini — sem isso configurado, o endpoint mostra
# tokens/latência normalmente mas custoEstimadoUsd fica null (não adivinha preço).
# GEMINI_PRECO_INPUT_POR_1M_USD=0.00
# GEMINI_PRECO_OUTPUT_POR_1M_USD=0.00

# ── OpaSuite (PABX) — validação de negociação real na auditoria de retenção ──
# Connection string completa do MongoDB do OpaSuite (somente leitura)
# OPASUITE_MONGO_URI=mongodb://usuario:senha@host:porta/?authSource=admin
# Nome do banco, se não vier embutido na URI acima
# OPASUITE_MONGO_DB=opasuite

# API REST oficial do OpaSuite (usuário com perfil de permissão "API",
# gerado no cadastro de usuários do próprio OpaSuite) — usada pra baixar
# áudio de ligações (transcrição na monitoria de QA) e, futuramente, pra
# escrever observação/etiqueta de volta no atendimento original.
# OPASUITE_API_URL=https://seu-dominio.opasuite.com.br
# OPASUITE_API_TOKEN=troque_pelo_token_gerado_no_opasuite

# Teto diário do job de análise em massa por IA (Motivo/Adesão ao
# Script/Sentimento, atendimento_analise_ia) — válvula de segurança contra
# pico de volume, não é uma amostra. Volume real medido em 2026-07-11: ~543
# atendimentos de texto/dia.
# LIMITE_ANALISE_IA_DIARIO=700

# Limiares dos alertas operacionais em tempo real (minutos, exceto
# FILA_BACKLOG que é contagem de conversas). Rodam a cada 2 min via cron.
# LIMIAR_CONVERSA_PARADA_MIN=10
# LIMIAR_SLA_FILA_MIN=5
# LIMIAR_AGENTE_AUSENTE_MIN=15
# LIMIAR_FILA_BACKLOG=5
# Teto (em horas) de quão antigo o atendimento pode ser pra ainda contar
# como "parada" urgente — evita tratar ticket esquecido há semanas em EA
# como se fosse urgência de agora (validado ao vivo em 2026-07-12).
# LIMIAR_CONVERSA_PARADA_JANELA_MAX_HORAS=24

# Limiares dos alertas de Vistoria de POP (dias). Rodam 1x/dia via cron.
# Pendência de segurança (Extintor/Gerador/Banco de Baterias) em aberto há
# mais desse tempo vira CRITICO.
# LIMIAR_PENDENCIA_SEGURANCA_DIAS=7
# POP sem vistoria há mais desse tempo vira AVISO.
# LIMIAR_POP_ATRASADO_DIAS=60

# URL pública do sistema de Vistoria de POP (botão "Fazer Vistoria" no
# frontend) — sem domínio/SSO por enquanto, IP direto até o time de infra
# fechar a exposição. Atualizar aqui (não no código) quando isso mudar.
# VISTORIA_POP_PUBLIC_URL=http://45.230.84.50:5002
