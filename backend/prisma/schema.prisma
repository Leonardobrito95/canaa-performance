generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["bdr", "hub", "comissao", "diagnostico", "infraestrutura"]
}

model Commission {
  id              String         @id @default(uuid())
  id_contrato     String
  nome_cliente    String
  vendedor        String
  tipo_negociacao TipoNegociacao
  plano_atual     String?
  plano_novo      String?
  valor_atual     Decimal        @db.Decimal(10, 2)
  valor_novo      Decimal?       @db.Decimal(10, 2)
  valor_comissao  Decimal        @db.Decimal(10, 2)
  criado_por      String?
  data_registro   DateTime       @default(now())

  @@map("commissions")
  @@schema("bdr")
}

enum TipoNegociacao {
  Upgrade
  Downgrade
  Refidelizacao

  @@schema("bdr")
}

model Adjustment {
  id             String    @id @default(uuid())
  vendedor       String
  descricao      String
  valor          Decimal   @db.Decimal(10, 2)
  registrado_por String
  data_registro  DateTime  @default(now())
  deletado_por   String?
  deletado_em    DateTime?

  @@map("adjustments")
  @@schema("bdr")
}

/// Snapshot mensal de comissões de Vendas — gerado todo dia 19 para o mês anterior.
/// Uma vez salvo, o registro não é alterado pelo IXC; reflete o estado no momento do fechamento.
model VendasSnapshot {
  id                String    @id @default(uuid())
  /// Mês de referência no formato "YYYY-MM" (ex: "2025-03" = março de 2025)
  mes_referencia    String
  id_contrato       String
  nome_cliente      String
  nome_vendedor     String
  plano             String
  segmento          String
  tipo_venda        String
  valor_mensal      Decimal   @db.Decimal(10, 2)
  percentual        Decimal   @db.Decimal(5, 4)
  valor_comissao    Decimal   @db.Decimal(10, 2)
  status_comissao   String
  motivo_bloqueio   String?
  assinatura        String
  /// Marcado como true quando o gestor clica em "Enviar para pagamento"
  enviado_pagamento Boolean   @default(false)
  data_envio        DateTime?
  enviado_por       String?
  data_snapshot     DateTime  @default(now())

  @@unique([mes_referencia, id_contrato])
  @@map("vendas_snapshots")
  @@schema("bdr")
}

// =============================================================================
// COMISSAO MODULE — Auditoria de comissão de campo (terceirizadas)
// =============================================================================

/// Tabela de empresas terceirizadas com tabela de preços por tipo de serviço.
model ComissaoCampoEmpresa {
  company_key String   @id
  nome        String
  precos_json Json     @default("{}")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("empresas")
  @@schema("comissao")
}

/// Resultado de auditoria salva por empresa (um registro por empresa, sobrescrito a cada auditoria).
model ComissaoCampoAuditoria {
  company_key  String    @id
  company_name String
  date_ini     DateTime?
  date_fim     DateTime?
  source       String    @default("database")
  summary_json Json      @default("{}")
  results_json Json      @default("[]")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("auditorias_salvas")
  @@schema("comissao")
}

// =============================================================================
// HUB MODULE — Portal analítico de roteamento de dashboards
// =============================================================================

model HubSector {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("fa-chart-bar")
  color       String   @default("#002F4D")
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  dashboards       HubDashboard[]
  sharedDashboards HubDashboardSharedSector[]
  userAccess       HubUserAccess[]

  @@map("sectors")
  @@schema("hub")
}

model HubDashboard {
  id                String    @id @default(uuid())
  title             String
  description       String?
  type              String // 'internal' | 'powerbi' | 'link'
  url               String
  status            String    @default("active") // 'active' | 'maintenance' | 'error' | 'archived'
  embed_mode        String    @default("newtab") // 'newtab' | 'iframe'
  thumbnail_url     String?
  business_rules    String?
  data_sources      String?
  owner_tech        String?
  refresh_frequency String?
  last_update       DateTime?
  sector_id         String?
  created_at        DateTime  @default(now())

  sector        HubSector?                 @relation(fields: [sector_id], references: [id])
  sharedSectors HubDashboardSharedSector[]
  userAccess    HubUserAccess[]
  accessLogs    HubAccessLog[]

  @@map("dashboards")
  @@schema("hub")
}

model HubDashboardSharedSector {
  dashboard_id String
  sector_id    String

  dashboard HubDashboard @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  sector    HubSector    @relation(fields: [sector_id], references: [id], onDelete: Cascade)

  @@id([dashboard_id, sector_id])
  @@map("dashboard_shared_sectors")
  @@schema("hub")
}

/// Permissões de acesso ao Hub por usuário IXC.
/// Um registro pode apontar para um setor (acesso a todos os dashboards do setor)
/// ou para um dashboard específico (acesso individual).
model HubUserAccess {
  id            String   @id @default(uuid())
  ixc_user_id   String
  ixc_user_nome String
  sector_id     String?
  dashboard_id  String?
  created_at    DateTime @default(now())
  created_by    String // IXC user ID de quem concedeu

  sector    HubSector?    @relation(fields: [sector_id], references: [id], onDelete: Cascade)
  dashboard HubDashboard? @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)

  @@map("user_access")
  @@schema("hub")
}

/// Log de auditoria do Hub — registra visualizações e ações administrativas.
model HubAccessLog {
  id           String   @id @default(uuid())
  ixc_user_id  String
  ixc_username String
  action       String // 'VIEW_DASHBOARD' | 'LOGIN' | 'CREATE_SECTOR' | 'UPDATE_DASHBOARD' etc.
  detail       String?
  ip_address   String?
  created_at   DateTime @default(now())

  dashboard_id String?
  dashboard    HubDashboard? @relation(fields: [dashboard_id], references: [id], onDelete: SetNull)

  @@map("access_logs")
  @@schema("hub")
}

// =============================================================================

/// Rastreamento de envio do relatório de comissão mensal (comercial e financeiro).
model ComissaoEnvioLog {
  id             String   @id @default(uuid())
  mes_referencia String
  tipo_envio     String // "COMERCIAL" | "FINANCEIRO"
  enviado_em     DateTime @default(now())
  enviado_por    String

  @@unique([mes_referencia, tipo_envio])
  @@map("comissao_envio_logs")
  @@schema("bdr")
}

/// Registro de negociação de valor em retenção (preenchido pelo CS após atendimento).
model RetencaoNegociacao {
  id_chamado      String   @id // ID da O.S. no IXC
  valor_original  Decimal  @db.Decimal(10, 2)
  valor_negociado Decimal  @db.Decimal(10, 2)
  descricao       String?
  registrado_por  String // nome do operador logado
  data_registro   DateTime @default(now())
  atualizado_em   DateTime @updatedAt

  @@map("retencao_negociacoes")
  @@schema("bdr")
}

/// Controle de alertas disparados por email — evita reenvio no mesmo período.
model AlertaEnviado {
  id             String   @id @default(uuid())
  /// Tipo: ASSINATURA_PENDENTE | FATURA_NAO_QUITADA | RETENCAO_META | RETENCAO_FIM_MES
  tipo           String
  /// id_contrato (vendas) ou nome_operador (retenção)
  referencia     String
  /// Mês de referência no formato "YYYY-MM"
  mes_referencia String
  /// Nível da meta atingida: '70' | '90' | '110' (somente para RETENCAO_META). Vazio nos demais.
  meta_nivel     String   @default("")
  enviado_em     DateTime @default(now())

  @@unique([tipo, referencia, mes_referencia, meta_nivel])
  @@map("alertas_enviados")
  @@schema("bdr")
}

// =============================================================================
// DIAGNOSTICO MODULE — Agente de IA (rede + instalação + comercial)
// =============================================================================

/// Consulta individual à IA — tanto o clique no botão padrão ("Analisar") quanto
/// uma pergunta livre feita no chat. Guardado permanentemente para auditoria.
model DiagnosticoConsulta {
  id                  String    @id @default(uuid())
  /// 'CLIENTE' | 'CONTRATO' | 'TECNICO' | 'OS'
  tipo_alvo           String
  id_alvo             String
  /// null = clique no botão padrão de análise; preenchido = pergunta livre no chat
  pergunta            String?
  resposta            String
  /// Snapshot do contexto usado na resposta (rede + O.S. + comercial) — auditável
  contexto_json       Json
  ixc_user_id         String
  ixc_username        String
  criado_em           DateTime  @default(now())
  /// 'POSITIVO' | 'NEGATIVO' — feedback de quem viu a resposta, se o
  /// diagnóstico/resposta estava correto. Fecha o loop de qualidade sem
  /// depender só de avaliação manual (eval script).
  feedback            String?
  feedback_comentario String?
  feedback_em         DateTime?
  /// Observabilidade da chamada ao Gemini que gerou essa resposta — custo e
  /// latência, pra ter visibilidade se o uso crescer, sem depender de vasculhar log.
  latencia_ms         Int?
  tokens_entrada      Int?
  tokens_saida        Int?
  modelo_usado        String?

  @@index([tipo_alvo, id_alvo])
  @@map("consultas")
  @@schema("diagnostico")
}

/// Visão agregada (painel de gestão) — um registro por dimensão analisada,
/// sobrescrito a cada recomputo. As métricas são calculadas em SQL (validadas);
/// a IA só gera a narrativa em cima de números já corretos.
model DiagnosticoAgregado {
  /// ex: "tecnico:552291", "causa:power_fail:brasilia"
  chave         String   @id
  /// 'TECNICO' | 'CAUSA_REDE' | 'REGIAO'
  dimensao      String
  periodo_ini   DateTime
  periodo_fim   DateTime
  metricas_json Json
  narrativa     String?
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([dimensao])
  @@map("agregados")
  @@schema("diagnostico")
}

/// Alertas automáticos gerados pelo agente a partir da visão agregada.
/// Dedup por período, mesmo padrão do AlertaEnviado (schema bdr).
model DiagnosticoAlerta {
  id         String   @id @default(uuid())
  tipo       String
  referencia String
  periodo    String
  narrativa  String
  enviado_em DateTime @default(now())

  @@unique([tipo, referencia, periodo])
  @@map("alertas")
  @@schema("diagnostico")
}

/// Referência de regras de negócio (metas, limiares) para o prompt da IA.
/// Cópia de leitura — não substitui as constantes usadas hoje pelo sistema de
/// produção (comissao-relatorio.service.ts, otdr_alertas.py etc.), só evita que
/// a IA raciocine com um limiar desatualizado ou inventado.
model DiagnosticoRegraNegocio {
  /// ex: 'META_B2C', 'META_B2B', 'META_BDR_UPGRADES', 'ATENUACAO_MAX_DB'
  chave          String   @id
  valor          String
  descricao      String
  /// 'VENDAS' | 'RETENCAO' | 'REDE' | 'COMISSAO' | 'ATENDIMENTO'
  categoria      String
  atualizado_em  DateTime @updatedAt
  atualizado_por String?

  @@map("regras_negocio")
  @@schema("diagnostico")
}

/// Auditoria de retenção: para cada O.S. de retenção (id_assunto=348) no IXC,
/// classifica se há evidência REAL de negociação no texto das mensagens (O.S. +
/// atendimento relacionado) — a classificação do IXC (id_su_diagnostico numa
/// lista fixa RETIDO/NAO_RETIDO) é genérica demais: conta "cliente aceitou
/// transferência de titularidade" e "cliente desistiu sem negociar" como
/// retido do mesmo jeito que "foi oferecido desconto e o cliente aceitou".
/// Só reporta a divergência — não altera o cálculo de comissão hoje.
model RetencaoAuditoria {
  id_chamado           String   @id // su_oss_chamado.id (IXC)
  nome_operador        String
  /// 'RETIDO' | 'NAO_RETIDO' | 'PENDENTE' — classificação original do IXC
  resultado_ixc        String
  /// 'NEGOCIACAO_REAL' | 'SEM_NEGOCIACAO' | 'INDEFINIDO' (evidência insuficiente no texto)
  classificacao        String
  justificativa        String
  negociacao_detectada String?
  /// Divergência entre a nota da O.S. (escrita pelo operador) e a conversa
  /// real do OpaSuite, quando encontrada — null = bateu, ou não havia
  /// conversa do OpaSuite pra comparar.
  divergencia_nota_os  String?
  data_abertura_os     DateTime
  classificado_em      DateTime @default(now())
  modelo_usado         String?

  @@index([nome_operador])
  @@index([classificacao])
  @@map("retencao_auditoria")
  @@schema("diagnostico")
}

/// Monitoria de qualidade do atendimento (SAC / Suporte N1 / Suporte N2) —
/// amostragem contínua via cron (não é 100% do volume, tem orçamento de
/// custo), avaliando a conversa real do OpaSuite contra uma régua fixa de
/// qualidade. 'canal' e 'classificacao' distinguem quando a única evidência
/// era uma ligação (canal pabx) sem transcrição — nesse caso não há como
/// avaliar de verdade, então classificacao='SEM_EVIDENCIA' e as notas ficam
/// null, em vez de a IA especular uma nota sem base.

/// Snapshot mensal pré-calculado dos KPIs de atendimento (1 linha por
/// setor x mês FECHADO). Existe porque calcular TMA/TME/TMR ao vivo no Mongo
/// do OpaSuite pra uma janela de vários meses é caro (medido: ~48s pra 3
/// meses x 3 setores em paralelo, inviável rodar a cada pergunta do chat de
/// gestão) — populado 1x/mês por rollup (ver atendimento.rollup.ts). O mês
/// corrente continua sendo calculado ao vivo (getResumoKpisAtendimento),
/// esse snapshot só cobre meses já fechados, pra dar tendência histórica.
model AtendimentoKpiMensal {
  id                     String   @id @default(uuid())
  /// 'SAC' | 'N1' | 'N2'
  setor                  String
  /// 'YYYY-MM'
  mes_referencia         String
  volume                 Int
  tma_ms                 Int?
  tme_ms                 Int?
  tmr_ms                 Int?
  escalonamentos         Int
  pct_escalonamento      Float?
  nota_media_satisfacao  Float?
  qtd_avaliados          Int
  calculado_em           DateTime @default(now())

  @@unique([setor, mes_referencia])
  @@index([mes_referencia])
  @@map("atendimento_kpi_mensal")
  @@schema("diagnostico")
}

/// Monitoria de qualidade do atendimento feita por QA HUMANO — incorporada do
/// sistema legado (Flask + SQLite, "Monitoria_Server.py") que rodava numa VM
/// separada. É a fonte de verdade de qualidade (não a monitoria por IA, que
/// foi aposentada) — o C.A.I.O. atua como copiloto sugerindo preenchimento,
/// nunca decidindo sozinho. `criterios` guarda os 22 campos Conforme/Não
/// Conforme/Não se aplica como JSON (em vez de 22 colunas) — ver
/// `atendimento.qa.types.ts` pras chaves e o algoritmo de pontuação.
model AtendimentoMonitoriaQa {
  id                  String    @id @default(uuid())
  /// `protocolo` NÃO é unique: confirmado empiricamente que o sistema legado
  /// tem 2 colisões reais em 7.861 linhas (protocolos diferentes só por
  /// espaço em branco, ou duplicata genuína) — duas avaliações DIFERENTES
  /// podem ter o mesmo número de protocolo. A chave de idempotência da
  /// migração é `id_legado` (o id da linha no SQLite original), não o
  /// protocolo. Registros criados daqui pra frente (origem=
  /// 'canaa_performance') não têm id_legado — a checagem de "protocolo já
  /// monitorado" pra esses é feita em código (não é constraint de banco),
  /// pra não herdar essa mesma armadilha pro futuro.
  id_legado           Int?      @unique
  protocolo           String
  data_atendimento    DateTime?
  data_monitoria      DateTime?
  nome_agente         String
  equipe              String
  motivo_atendimento  String?
  /// Categoriza qual tipo de zero ocorreu (Ofensa Verbal, Erro de
  /// Procedimento...) quando houver — dropdown próprio, não confundir com
  /// `erro_critico` (calculado a partir do critério "Omissão de atendimento").
  monitoria_zero      String?
  /// Nota geral do atendente (escala 0-5), separada da `pontuacao` (0-10).
  avaliacao_atd       Float?
  erro_critico        Boolean   @default(false)
  itens_aplicaveis    Int?
  pontuacao           Float?
  observacoes         String?
  /// Critério antigo, descontinuado antes da migração — preservado só por
  /// completude histórica, NÃO entra no cálculo de pontuação atual.
  ofensa_verbal_legado String?
  /// Os 22 critérios Conforme/Não Conforme/Não se aplica (ver YES_NO_FIELDS
  /// em atendimento.qa.types.ts) como JSON: { "Cordialidade": "Conforme", ... }
  ///
  /// ATENÇÃO: `pontuacao`/`itens_aplicaveis`/`erro_critico` em registros
  /// migrados (origem='legado') são os valores ORIGINAIS já calculados pelo
  /// sistema antigo no momento da avaliação — NÃO recalcular a partir de
  /// `criterios` com os pesos atuais de PENALIZACOES_QA. Confirmado
  /// empiricamente (2026-07-11): os pesos de penalização mudaram ao longo do
  /// tempo no sistema legado, então recalcular pontuação antiga com pesos
  /// de hoje reescreveria retroativamente uma decisão de qualidade já
  /// tomada (ex: 191/500 dos registros mais antigos "divergem" dos pesos
  /// atuais — isso é esperado, não é erro de migração; os 500 mais recentes
  /// batem 100% porque usam os mesmos pesos vigentes hoje).
  criterios           Json
  /// 'legado' (migrado do sistema antigo) | 'canaa_performance' (criado aqui)
  origem              String    @default("legado")
  /// ixc_user_id de quem fez a avaliação — null nos registros migrados do
  /// legado (não temos essa informação lá, só usuário do sistema antigo).
  avaliado_por        String?
  /// "Ciência" do agente avaliado — ele vê a própria nota e confirma/comenta.
  /// null enquanto não foi comunicado. Não é aprovação, é só registro de
  /// que o agente tomou ciência (ele pode discordar no comentário).
  comunicado_em       DateTime?
  comunicado_nota     String?
  criado_em           DateTime  @default(now())
  atualizado_em       DateTime  @updatedAt

  @@index([protocolo])
  @@index([equipe])
  @@index([nome_agente])
  @@index([data_atendimento])
  @@map("atendimento_monitoria_qa")
  @@schema("diagnostico")
}

/// Roster de agentes curado manualmente pelo QA (migrado do sistema legado) —
/// alimenta o dropdown de agente do formulário de monitoria. Independente do
/// OpaSuite de propósito: permite cadastrar/desativar agente sem depender de
/// atividade real lá (ex: agente novo ainda não logou no OpaSuite).
model AtendimentoAgenteQa {
  id           String   @id @default(uuid())
  nome         String   @unique
  equipe       String
  /// 'Ativo' | 'Inativo'
  status       String
  /// Link real com o usuário do IXC (pra "Minhas Avaliações"/ciência) —
  /// preferido sobre bater por nome, que já mostrou ser frágil (diferença de
  /// grafia entre o roster e o cadastro do IXC, confirmado empiricamente
  /// 2026-07-12: 4 de 13 agentes ativos não bateram por nome). Populado por
  /// script pontual de reconciliação, não automaticamente.
  ixc_user_id  String?  @unique
  criado_em    DateTime @default(now())

  @@map("atendimento_agente_qa")
  @@schema("diagnostico")
}

/// Camada analítica de IA em massa (Motivo/Adesão ao Script/Sentimento) —
/// processa quase todo o volume de atendimentos de TEXTO (não amostra), pra
/// preencher a lacuna de tipificação (só 42% dos atendimentos têm "motivos"
/// preenchido no OpaSuite) e priorizar a fila de QA pelos piores casos.
///
/// ATENÇÃO: isso NÃO é uma "nota oficial" de QA e nunca deve ser confundido
/// com `AtendimentoMonitoriaQa` — é sinal de triagem gerado por IA que
/// NINGUÉM revisou ainda. A avaliação oficial (22 critérios, pontuação
/// 0-10) continua 100% controlada por humano naquela tabela separada. Essa
/// separação é deliberada, mesmo raciocínio que levou a aposentar a
/// monitoria por IA de 3 critérios nesta mesma sessão.
model AtendimentoAnaliseIa {
  id                      String    @id @default(uuid())
  /// Chave de idempotência = _id do Mongo do OpaSuite (atendimento), NUNCA
  /// protocolo — 2 colisões reais já confirmadas na migração de QA (ver
  /// AtendimentoMonitoriaQa.id_legado), mesma lição aplicada aqui desde o
  /// início em vez de repetir o erro.
  opasuite_atendimento_id String    @unique
  protocolo               String
  setor                   String
  canal                   String
  data_atendimento        DateTime
  /// Sempre de uma lista FECHADA (distinct de motivo_atendimentos do
  /// OpaSuite) + "Outro" — nunca texto livre, senão fragmenta o ranking
  /// (ex: "Sinal instável" vs "Problema de sinal" virariam 2 linhas
  /// diferentes em vez de uma).
  motivo_classificado     String?
  /// Espelha o heurístico já usado no copiloto de QA (DEFINICAO_CRITERIO
  /// ['Script'] = "seguiu abertura/fechamento?") — não existe nem é preciso
  /// existir um documento de script literal pra IA comparar palavra a
  /// palavra.
  adesao_script           Float?
  indice_sentimento       Float?
  /// 'muito_negativo' | 'negativo' | 'neutro' | 'positivo' | 'muito_positivo'
  sentimento_categoria    String?
  justificativa           String?
  /// true quando a conversa é curta/ambígua demais pra IA avaliar com
  /// confiança (mesmo espírito do "canal pabx / <2 mensagens" já tratado no
  /// copiloto de QA) — quando true, adesao_script/indice_sentimento ficam
  /// null e NÃO viram sinal de nota ruim por falta de dado.
  confianca_insuficiente  Boolean   @default(false)
  /// Calculado no momento do processamento a partir de um corte por
  /// PERCENTIL sobre a distribuição real (calibrado na fase piloto), não um
  /// valor fixo cravado no código.
  flag_triagem            Boolean   @default(false)
  modelo_usado            String?
  processado_em           DateTime  @default(now())

  @@index([setor])
  @@index([flag_triagem])
  @@map("atendimento_analise_ia")
  @@schema("diagnostico")
}

/// Alertas operacionais em tempo real (conversa parada, SLA de fila
/// estourado, agente ausente demais, fila acumulada) — granularidade por
/// conversa/agente individual, diferente dos alertas agregados de
/// volume/escalonamento já existentes (alertas.service.ts, que continuam
/// indo por e-mail). Isso aqui é um feed dentro do próprio Canaã Performance
/// (não manda e-mail/WhatsApp — ver feedback do usuário sobre não lotar os
/// canais existentes), consultado sob demanda pelo gestor/QA.
model AtendimentoAlertaOperacional {
  id                      String    @id @default(uuid())
  /// 'CONVERSA_PARADA' | 'SLA_FILA' | 'AGENTE_AUSENTE' | 'FILA_ACUMULADA'
  tipo                    String
  /// 'AVISO' | 'CRITICO'
  severidade              String
  titulo                  String
  descricao               String
  setor                   String
  /// _id do Mongo do OpaSuite — só preenchido pra alertas de 1 conversa
  /// específica (CONVERSA_PARADA, SLA_FILA). String vazia (não null) quando
  /// não se aplica — Postgres trata NULL como distinto de NULL em constraint
  /// unique, o que quebraria o dedup de FILA_ACUMULADA (2+ alertas do mesmo
  /// setor com os 2 campos NULL não seriam pegos como duplicata).
  opasuite_atendimento_id String    @default("")
  /// Só preenchido pra alertas de 1 agente específico (AGENTE_AUSENTE).
  /// String vazia (não null) pelo mesmo motivo acima.
  agente_nome             String    @default("")
  /// 'ABERTO' | 'RESOLVIDO'
  status                  String    @default("ABERTO")
  criado_em               DateTime  @default(now())
  resolvido_em            DateTime?

  /// Dedup — nunca duplica o mesmo alerta aberto pro mesmo alvo (conversa,
  /// agente, ou setor no caso de FILA_ACUMULADA).
  @@unique([tipo, setor, opasuite_atendimento_id, agente_nome])
  @@index([status])
  @@map("atendimento_alerta_operacional")
  @@schema("diagnostico")
}

/// Alertas do sistema de Vistoria de POP (porta 5002, incorporado via leitura
/// direta de public.vistoria_pop/vistoria_pendencias — ver vistoriaPop.repository.ts).
/// Schema PRÓPRIO ("infraestrutura"), diferente do schema `public` onde
/// vistoria_pop/vistoria_pendencias vivem — essas tabelas pertencem ao
/// sistema externo (só lidas via $queryRaw, nunca modeladas/migradas aqui);
/// esse model é dado que o Canaã Performance CRIA e é dono, mesmo padrão já
/// usado pro schema `diagnostico` vs a leitura raw do schema `otdr`.
model VistoriaAlerta {
  id           String    @id @default(uuid())
  /// 'PENDENCIA_SEGURANCA' | 'POP_ATRASADO'
  tipo         String
  /// 'AVISO' | 'CRITICO'
  severidade   String
  titulo       String
  descricao    String
  pop_name     String    @default("")
  /// id de public.vistoria_pendencias — só preenchido pra PENDENCIA_SEGURANCA
  /// (POP_ATRASADO é por POP, sem pendência específica). String vazia (não
  /// null) pelo mesmo motivo já documentado em AtendimentoAlertaOperacional
  /// (NULL não deduplica em constraint unique do Postgres).
  pendencia_id String    @default("")
  /// 'ABERTO' | 'RESOLVIDO'
  status       String    @default("ABERTO")
  criado_em    DateTime  @default(now())
  resolvido_em DateTime?

  @@unique([tipo, pop_name, pendencia_id])
  @@index([status])
  @@map("vistoria_alerta")
  @@schema("infraestrutura")
}
